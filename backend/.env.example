PORT=5000
# Pakai MongoDB Atlas (cloud) — ganti dengan connection string dari dashboard Atlas
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/belajar-3t
JWT_SECRET=change_this_secret
JWT_EXPIRES_IN=7d
# Jika muncul error "querySrv ECONNREFUSED" saat connect ke MongoDB Atlas, backend otomatis
# memakai DNS publik (1.1.1.1, 8.8.8.8) untuk resolve mongodb+srv://. Ganti daftar server di
# bawah bila perlu, atau set DNS_OVERRIDE=false untuk memakai resolver DNS sistem apa adanya.
# DNS_OVERRIDE=false
# DNS_SERVERS=1.1.1.1,8.8.8.8
OLLAMA_HOST=http://localhost:11434
# Nama model Ollama untuk AI Tutor (lihat /edunusa-model). Ganti saat testing model versi lain.
EDUNUSA_MODEL=edunusa
CORS_ORIGIN=http://localhost:5173
